# Production Environment Configuration
VITE_API_BASE_URL=https://api.tflmonitoring.com/api
VITE_WS_URL=wss://api.tflmonitoring.com/ws

# TFL Section 16: Refresh Intervals (milliseconds)
VITE_REFRESH_INTERVAL_LIVE_FEED=1000
VITE_REFRESH_INTERVAL_KPIS=5000
VITE_REFRESH_INTERVAL_HEATMAP=10000
VITE_REFRESH_INTERVAL_ALERTS=5000

# Feature Flags
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_REAL_TIME_UPDATES=true
VITE_ENABLE_EXPORT_FEATURES=true

# Debug Settings
VITE_DEBUG_MODE=false
VITE_SHOW_PERFORMANCE_METRICS=false

# Security Settings
VITE_ENABLE_HTTPS=true
VITE_STRICT_SSL=true
